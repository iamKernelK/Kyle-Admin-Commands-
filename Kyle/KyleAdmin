local Commands = {
    ["Fly"] = {
        Description = "الطيران بسرعة محددة (Fly [speed])",
        Action = function(speed)
            local speed = tonumber(speed) or 50
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum then return end
            if ActiveStates.FlyStop then ActiveStates.FlyStop() end
            
            hum.PlatformStand = true
            local bv = Instance.new("BodyVelocity", hrp); bv.MaxForce = Vector3.new(1/0, 1/0, 1/0)
            local bg = Instance.new("BodyGyro", hrp); bg.MaxTorque = Vector3.new(1/0, 1/0, 1/0); bg.P = 10000
            local anim = Instance.new("Animation"); anim.AnimationId = "rbxassetid://507765000"
            local track = hum:LoadAnimation(anim); track:Play()
            
            ActiveStates.FlyLoop = RunService.RenderStepped:Connect(function()
                local cam = workspace.CurrentCamera
                local moveDir = hum.MoveDirection
                local lv = cam.CFrame.LookVector
                local rv = cam.CFrame.RightVector
                local flatLv = Vector3.new(lv.X, 0, lv.Z).Unit
                local flatRv = Vector3.new(rv.X, 0, rv.Z).Unit
                
                if moveDir.Magnitude > 0 then
                    local forwardMove = flatLv:Dot(moveDir)
                    local rightMove = flatRv:Dot(moveDir)
                    bv.Velocity = (lv * forwardMove + rv * rightMove).Unit * speed
                else
                    bv.Velocity = Vector3.zero
                end
                bg.CFrame = cam.CFrame
            end)
            
            ActiveStates.FlyStop = function()
                hum.PlatformStand = false; if bv then bv:Destroy() end; if bg then bg:Destroy() end
                if track then track:Stop() end; if ActiveStates.FlyLoop then ActiveStates.FlyLoop:Disconnect() end
                ActiveStates.FlyStop = nil
            end
        end
    },
    ["UnFly"] = { Description = "إيقاف الطيران", Action = function() if ActiveStates.FlyStop then ActiveStates.FlyStop() end end },
    
    ["Speed"] = {
        Description = "تغيير سرعة اللاعب (Speed [number])",
        Action = function(v)
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
            if hum then
                _G.PrevWalkSpeed = hum.WalkSpeed
                hum.WalkSpeed = tonumber(v) or 16
            end
        end
    },
    ["ResetSpeed"] = { Description = "إرجاع السرعة للطبيعي", Action = function() local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid"); if hum then hum.WalkSpeed = 16 end end },
    
    ["Jumppower"] = {
        Description = "تغيير قوة القفز (Jumppower [number])",
        Action = function(v)
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
            if hum then
                hum.UseJumpPower = true
                hum.JumpPower = tonumber(v) or 50
            end
        end
    },
    ["ResetJumpPower"] = { Description = "إرجاع القفز للطبيعي", Action = function() local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid"); if hum then hum.JumpPower = 50 end end },

    ["Infjump"] = { 
        Description = "القفز اللانهائي",
        Action = function() 
            ActiveStates.Infjump = true 
            if not ActiveStates.InfJumpConn then
                ActiveStates.InfJumpConn = UserInputService.JumpRequest:Connect(function()
                    if ActiveStates.Infjump and os.clock() - lastInfJump >= 0.2 then
                        lastInfJump = os.clock()
                        LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
                    end
                end)
            end
        end 
    },
    ["UnInfjump"] = { Description = "إيقاف القفز اللانهائي", Action = function() ActiveStates.Infjump = false end },

    ["Morph"] = {
        Description = "تحويل شكلك لشكل لاعب آخر (Morph [username])",
        Action = function(targetName)
            pcall(function()
                local id = Players:GetUserIdFromNameAsync(targetName)
                local desc = Players:GetHumanoidDescriptionFromUserId(id)
                LocalPlayer.Character.Humanoid:ApplyDescription(desc)
                ActiveStates.CurrentMorphID = id
            end)
        end
    },
    
    ["Rejoin"] = { Description = "إعادة الدخول لنفس السيرفر", Action = function() TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer) end },
    ["Jobid"] = { Description = "نسخ كود السيرفر", Action = function() setclipboard_safe(game.JobId) end },
    ["ServerHop"] = { 
        Description = "الانتقال لسيرفر عشوائي",
        Action = function() 
            local r = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"))
            if r and r.data then TeleportService:TeleportToPlaceInstance(game.PlaceId, r.data[math.random(1,#r.data)].id) end
        end 
    },

    ["CopyPos"] = { Description = "نسخ إحداثيات مكانك", Action = function() if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then setclipboard_safe(tostring(LocalPlayer.Character.HumanoidRootPart.Position)) end end },
    ["SavePos"] = { Description = "حفظ مكانك الحالي للرجوع إليه", Action = function() if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then _G.SavedPos = LocalPlayer.Character.HumanoidRootPart.CFrame end end },
    ["LoadPos"] = { Description = "الرجوع للمكان المحفوظ", Action = function() if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then LocalPlayer.Character.HumanoidRootPart.CFrame = _G.SavedPos end end },
    
    ["Fullbright"] = { Description = "إضاءة كاملة للماب", Action = function() Lighting.Brightness = 2; Lighting.OutdoorAmbient = Color3.new(1,1,1) end },
    ["Day"] = { Description = "تحويل الوقت للنهار", Action = function() Lighting.TimeOfDay = "12:00:00" end },
    ["Night"] = { Description = "تحويل الوقت لليل", Action = function() Lighting.TimeOfDay = "24:00:00" end },
    
    ["Noclip"] = { 
        Description = "المرور عبر الجدران",
        Action = function() 
