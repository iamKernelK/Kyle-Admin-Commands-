local url = "https://raw.githubusercontent.com/iamKernelK/Kyle-Admin-Commands-/refs/heads/main/Kyle/UI.lua"

local success, response = pcall(function()
    return game:HttpGet(url)
end)

if success and response and response ~= "404: Not Found" then
    local func, err = loadstring(response)
    if func then
        func()
    else
        warn("Error loading string: " .. tostring(err))
    end
else
    warn("Failed to fetch script from URL. Check your link or internet connection.")
end
